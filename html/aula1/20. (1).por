programa {
  funcao inicio() {
     inteiro a=0
     inteiro b=0

     escreva ("Qual a idade da 1ª pessoa?")
     leia(a)

     escreva ("Qual a idade da 2ª pessoa?")
    leia(b)

     se (a>b){
      escreva("A 1ª pessoa é mais velha, com ",a, " anos")
     }

     senao{
      escreva ("A 2ª pessoa é mais velha, com ",b," anos")
     }
  }
}
