programa {
  funcao inicio() {
    
    inteiro tabuada
    inteiro n1
    inteiro n2

    para(n1=1; n1<=10; n1++){
      escreva ("Tabuada do ",n1,"\n")
    
      para(n2=1;n2<=10;n2++){
         tabuada= n1*n2
        escreva ("A tabuada completa: ",tabuada,"\n")
      }
    
      
    }
  }
}
